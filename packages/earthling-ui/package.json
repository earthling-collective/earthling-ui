{
  "name": "earthling-ui",
  "version": "1.1.0-alpha.39",
  "homepage": "https://ui.earthling.dev",
  "bugs": "https://github.com/earthling-dev/earthling-ui/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/earthling-dev/earthling-ui.git",
    "directory": "packages/earthling-ui"
  },
  "license": "MIT",
  "author": {
    "name": "Steven Frady",
    "email": "sFrady20@gmail.com",
    "url": "https://stevenfrady.com"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/components/index.d.ts",
        "default": "./dist/components/index.js"
      },
      "require": {
        "types": "./dist/cjs/components/index.d.ts",
        "default": "./dist/cjs/components/index.js"
      },
      "style": "./src/index.css"
    },
    "./index.css": "./src/index.css",
    "./themes/*.css": "./src/themes/*.css",
    "./theme/*": {
      "style": "./src/themes/*.css"
    },
    "./utils/*": {
      "import": {
        "types": "./dist/utils/*.d.ts",
        "default": "./dist/utils/*.js"
      },
      "require": {
        "types": "./dist/cjs/utils/*.d.ts",
        "default": "./dist/cjs/utils/*.js"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/components/*/index.d.ts",
        "default": "./dist/components/*/index.js"
      },
      "require": {
        "types": "./dist/cjs/components/*/index.d.ts",
        "default": "./dist/cjs/components/*/index.js"
      }
    }
  },
  "main": "./dist/cjs/components/index.js",
  "module": "./dist/components/index.js",
  "types": "./dist/components/index.d.ts",
  "style": "./src/index.css",
  "bin": {
    "earthling-ui": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "cross-env NODE_ENV=production bun run scripts/build.ts",
    "dev": "bun run build && chokidar \"src/**/*.{ts,tsx}\" -c \"bun run scripts/build.ts\""
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@iconify/tailwind4": "^1.2.1",
    "commander": "^14.0.2",
    "find-parent-dir": "^0.3.1",
    "isomorphic-git": "^1.36.1"
  },
  "devDependencies": {
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "clsx": "^2.1.1",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-hover-card": "^1.1.16",
    "@radix-ui/react-menubar": "^1.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@types/bun": "^1.3.6",
    "@types/find-parent-dir": "^0.3.3",
    "@types/node": "^22.19.7",
    "bun": "^1.3.6",
    "bun-plugin-dts": "^0.3.0",
    "chokidar-cli": "^3.0.0",
    "class-variance-authority": "^0.7.1",
    "cross-env": "^7.0.3",
    "react-aria-components": "^1.18.0",
    "tailwind-merge": "^3.6.0",
    "type-fest": "^4.41.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
